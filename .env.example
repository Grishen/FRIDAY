# Copy to repo root `.env` and/or `services/api/.env` (API loads `.env` from cwd when you run uvicorn inside `services/api`).
#
# API (services/api)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/friday
SYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/friday
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
SECRET_KEY=change-me-in-production
# Include both hostname spellings — Next/Electron sometimes uses 127.0.0.1:3000 while dev uses localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Web (apps/web). Use 127.0.0.1 so fetch targets the same stack as `./scripts/run-api.sh` (uvicorn binds 127.0.0.1:8000).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# OpenTelemetry — API exports traces via OTLP HTTP/protobuf when OTEL_ENABLED=true (Phase 13).
# Local collector: Compose service `otel-collector` listens on localhost:4317 (gRPC) and :4318 (HTTP).
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=friday-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces
# OTEL_SDK_DISABLED=false

# OpenAI (`services/api`): put your real **`OPENAI_API_KEY`** in **`services/api/.env`** unless you intentionally
# **`./scripts/run-api.sh --sync-env-from-root`** to copy this root file over (see **`scripts/run-api.sh`** comments).
#
# Personal OS assistant — streaming LLM (optional) + sandboxed host tools (optional).
# OPENAI_API_KEY=sk-proj-...         # omit = mock chat · For hosted OpenAI/STT/Realtime use a real key; for Ollama chat any non-empty placeholder works
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_WHISPER_MODEL=whisper-1
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_REALTIME_VOICE=marin
# FRIDAY_REALTIME_INSTRUCTIONS=You are FRIDAY — voice copilot. Keep replies speakable…
# LLM_STREAMING=true
# STT_MAX_UPLOAD_BYTES=5242880   # multipart + voice.audio payloads
#
# --- Local conversational LLM: Ollama (OpenAI-compatible, $0 cloud for chat) ---
# Install app + CLI: https://ollama.com/download  (macOS: `brew install ollama`, then `brew services start ollama` or run `ollama serve`.)
# Models are pulled on demand — quality vs RAM roughly:
#   `ollama pull llama3.1:8b`     — recommended default for conversation vs size (Meta license; ~8 GB class machines)
#   `ollama pull qwen2.5:14b`     — strong reasoning / instruction-following if you have more RAM
#   `ollama pull llama3.2:3b`     — smallest/fastest usable chat if memory is tight
# Point FRIDAY’s chat provider at Ollama; API key **must be non-empty** or the backend uses MockChatProvider (see providers/factory.py).
# OPENAI_API_KEY=local-ollama
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_CHAT_MODEL=llama3.1:8b
# Note: STT (/audio/transcriptions) and Realtime WebRTC still expect OpenAI-shaped hosted APIs unless you run additional local proxies.

# Coqui TTS — pick one backend (API `services/api`, do not expose keys to the browser).
# COQUI_TTS_BACKEND=remote          # legacy Studio HTTP (discontinued)
# COQUI_TTS_BACKEND=local_http      # local sidecar: ./scripts/run-coqui-local-tts.sh
# COQUI_LOCAL_TTS_URL=http://127.0.0.1:8787
# Remote-only (if you still have a compatible host):
# COQUI_API_TOKEN=
# COQUI_VOICE_ID=
# COQUI_API_BASE_URL=https://app.coqui.ai
# Sidecar env (process that runs coqui-local-tts, not friday-api):
# COQUI_SPEAKER_WAV=/absolute/path/to/reference.wav
# COQUI_XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
# COQUI_USE_GPU=false
# COQUI_LANGUAGE=en
# COQUI_TTS_SPEED=1.0
# Phrase wake: comma-separated substrings (multi-word) or single tokens (word-boundary match).
# FRIDAY_WAKE_PHRASES=friday, hey friday, hey buddy friday
# NEXT_PUBLIC_USE_COQUI_TTS=1

# FRIDAY_LOCAL_WORKSPACE=/absolute/path/friday-workspace
# FRIDAY_OPEN_APP_ALLOWLIST=Calculator,Safari,Terminal

# Desktop (apps/desktop) — optional; default UI is http://127.0.0.1:3000 when unset
# FRIDAY_WEB_URL=http://127.0.0.1:3000
# FRIDAY_WAIT_SERVER_MS=120000
