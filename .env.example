# Copy to repo root `.env` and/or `services/api/.env` (API loads `.env` from cwd when you run uvicorn inside `services/api`).
#
# API (services/api)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/friday
SYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/friday
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
SECRET_KEY=change-me-in-production
# Include both hostname spellings — Next/Electron sometimes uses 127.0.0.1:3000 while dev uses localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Web (apps/web). Use 127.0.0.1 so fetch targets the same stack as `./scripts/run-api.sh` (uvicorn binds 127.0.0.1:8000).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# OpenTelemetry — API exports traces via OTLP HTTP/protobuf when OTEL_ENABLED=true (Phase 13).
# Local collector: Compose service `otel-collector` listens on localhost:4317 (gRPC) and :4318 (HTTP).
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=friday-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces
# OTEL_SDK_DISABLED=false

# Personal OS assistant — streaming LLM (optional) + sandboxed host tools (optional).
# OPENAI_API_KEY=                    # omit = mock completions
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_WHISPER_MODEL=whisper-1
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_REALTIME_VOICE=marin
# FRIDAY_REALTIME_INSTRUCTIONS=You are FRIDAY — voice copilot. Keep replies speakable…
# LLM_STREAMING=true
# STT_MAX_UPLOAD_BYTES=5242880   # multipart + voice.audio payloads

# Wake word (apps/web Porcupine WASM). Access key comes from Picovoice Console — safe to expose publicly.
# NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=
# NEXT_PUBLIC_WAKE_BUILTIN=Jarvis
# NEXT_PUBLIC_PICOVOICE_MODEL_URL=https://raw.githubusercontent.com/Picovoice/porcupine/master/lib/common/porcupine_params.pv

# FRIDAY_LOCAL_WORKSPACE=/absolute/path/friday-workspace
# FRIDAY_OPEN_APP_ALLOWLIST=Calculator,Safari,Terminal

# Desktop (apps/desktop) — optional; default UI is http://127.0.0.1:3000 when unset
# FRIDAY_WEB_URL=http://127.0.0.1:3000
# FRIDAY_WAIT_SERVER_MS=120000
