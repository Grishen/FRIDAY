# =============================================================================
# Jarvis / FRIDAY assistant — environment template
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in the keys you actually have:
#     cp .env.template .env
# Then either:
#   * `pip install python-dotenv` so values auto-load, or
#   * `source .env` (zsh/bash) in the same shell before `python main.py`.
#
# Everything is OPTIONAL. The assistant will run with zero keys set — features
# requiring a missing key just degrade gracefully (e.g. no brain, no vision).
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Conversational brain (unlocks LLM features, vision, sentiment, briefing
#    synthesis, summarization, unified-ask, etc.)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=                    # https://platform.openai.com/api-keys
OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_VISION_MODEL=                 # defaults to OPENAI_CHAT_MODEL (use a vision-capable model, e.g. gpt-4o, gpt-4o-mini)

# --- Live multi-modal observers ---------------------------------------------
# Live camera daemon (periodic webcam frames; conservative alerts only):
# JARVIS_LIVE_CAMERA_PERIOD_S=60
# JARVIS_LIVE_CAMERA_CHANGE=0.05       # 0..1 pixel-diff threshold for "movement"
# JARVIS_LIVE_CAMERA_SEATED_WARN_MIN=90
# JARVIS_LIVE_CAMERA_COOLDOWN_S=1800
# Live screen daemon (periodic screenshots; only fires for error/stuck states):
# JARVIS_LIVE_SCREEN_PERIOD_S=90
# JARVIS_LIVE_SCREEN_CHANGE=0.02
# JARVIS_LIVE_SCREEN_STUCK_MIN=6       # min minutes on same screen before checking
# JARVIS_LIVE_SCREEN_COOLDOWN_S=600

# --- Situational awareness / sound monitor ----------------------------------
# Sound monitor (loud-burst / doorbell / phone / alarm detection):
# JARVIS_SOUND_TRIGGER_RATIO=4.5       # current RMS / noise floor to fire
# JARVIS_SOUND_MIN_MS=220              # required duration to count as an event
# JARVIS_SOUND_COOLDOWN_S=30           # min seconds between events
# JARVIS_SOUND_CLIP_S=1.5              # how much audio to capture for classification
# JARVIS_SOUND_ALERT_BURSTS=0          # 1 to also announce generic loud sounds

# --- Ambient / proactive daemon ---------------------------------------------
# Background watcher that surfaces meetings, reminders, idle check-ins, etc.
# JARVIS_AMBIENT=1                     # 0 to disable proactive speech entirely
# JARVIS_AMBIENT_TICK=20               # seconds between check loops
# JARVIS_AMBIENT_MIN_GAP=60            # minimum seconds between any two proactive utterances
# JARVIS_AMBIENT_QUIET=22-7            # quiet hours (24h, start-end; wraps midnight)
# JARVIS_AMBIENT_IDLE_MIN=45           # silence (min) before an idle check-in
# JARVIS_AMBIENT_MEETING_LEAD_MIN=5    # how many minutes before a meeting to brief
# JARVIS_AMBIENT_DEBUG=0               # 1 to log check exceptions to stderr

# --- Real-time voice (Whisper STT + VAD + streaming TTS) ---------------------
# Speech-to-text backend selection:
#   auto             — first available of: faster_whisper → whisper → openai_api → google
#   faster_whisper   — pip install faster-whisper (recommended; offline, fast)
#   whisper          — pip install openai-whisper (offline)
#   openai_api       — uses OPENAI_API_KEY (online, very accurate)
#   google           — legacy free Google web API (no install, lowest quality)
# JARVIS_STT_BACKEND=auto              # auto prefers: faster_whisper → whisper → google → openai_api
# JARVIS_USE_WHISPER=auto              # 1=force on, 0=force off, auto=use if available
# pip install faster-whisper           # recommended local STT (no OpenAI quota needed)
# JARVIS_WHISPER_MODEL=base.en         # faster-whisper sizes: tiny.en/base.en/small.en/medium.en/large-v3
# JARVIS_WHISPER_DEVICE=auto           # cpu | cuda | auto
# JARVIS_WHISPER_LANG=en               # '' to auto-detect
# JARVIS_WHISPER_COMPUTE=int8          # int8 | int8_float16 | float16 | float32
#
# Voice Activity Detection backend (for natural end-of-utterance):
#   auto    — silero (best) → webrtc → rms
# JARVIS_VAD_BACKEND=auto
# JARVIS_VAD_WEBRTC_AGGRESSIVENESS=2   # 0..3
# JARVIS_VAD_SILERO_THRESH=0.5
#
# Mic capture timing:
# JARVIS_STT_SAMPLE_RATE=16000
# JARVIS_STT_FRAME_MS=30
# JARVIS_STT_MAX_SECONDS=30
# JARVIS_STT_PRE_ROLL_MS=300
# JARVIS_STT_SILENCE_MS=700            # silence required to end utterance
# JARVIS_STT_START_TIMEOUT=8
#
# ElevenLabs streaming voice settings (used by tts_stream.speak_stream):
# ELEVENLABS_STABILITY=0.45
# ELEVENLABS_SIMILARITY=0.85
# ELEVENLABS_STYLE=0.20
# ELEVENLABS_SPEAKER_BOOST=true
#
# Optional installs to unlock real-time voice:
#   pip install sounddevice faster-whisper webrtcvad silero-vad
#   brew install ffmpeg                # streaming TTS via ffplay pipe
#
# --- Vision / camera ---------------------------------------------------------
# Webcam selection (0 = built-in / first attached).
# JARVIS_WEBCAM_INDEX=0
# JARVIS_WEBCAM_DEVICE=                # ffmpeg-only: dshow video=Name (Win) or /dev/videoN (Linux)
# Image generation model (text → image)
# OPENAI_IMAGE_GEN_MODEL=gpt-image-1   # alternatives: dall-e-3, dall-e-2
# Vision performance / quality
# JARVIS_VISION_MAX_PIXELS=4194304     # downscale ceiling per image (~4MP) to save tokens
# JARVIS_VISION_HISTORY=8              # how many recent images to remember (powers compare/follow-up)
# JARVIS_VISION_RECENT_HOURS=24        # window when finding "the recent download/screenshot"
#
# Recommended optional packages (each missing is handled gracefully):
#   pip install Pillow pillow-heif pymupdf opencv-python pytesseract requests
#
# macOS extras:
#   brew install imagesnap pngpaste ffmpeg tesseract
#   imagesnap = best webcam capture | pngpaste = broader clipboard formats
#   tesseract = local OCR fallback   | sips (built-in) = HEIC → PNG fallback

# Persona: `jarvis` (default — British butler) or `friday` (ops-chief).
JARVIS_BRAIN_PERSONA=friday
# JARVIS_BRAIN_SYSTEM_PROMPT=          # full override — replaces persona preset
# JARVIS_BRAIN_TOOL_ROUNDS=6           # max assistant↔tool loops per turn
# JARVIS_STREAM_TTS=1                  # stream sentence-by-sentence (lower latency, mood voice)
# JARVIS_SPEAKER_ID=auto               # match voiceprint → auto-switch user (0 to disable)
# JARVIS_SPEAKER_THRESHOLD=0.82      # cosine similarity for user match
# JARVIS_SPEAKER_ID_ANNOUNCE=1         # brief greeting when switching to a recognized user
#
# --- Tier 2: human-like interaction ------------------------------------------
# JARVIS_BACKCHANNEL=0                 # murmur "mm-hmm" during long user speech (use headphones)
# JARVIS_BACKCHANNEL_AFTER=4           # seconds of user speech before backchannel
# JARVIS_BACKCHANNEL_GAP=8             # min seconds between backchannels
# JARVIS_RELATIONSHIP_MEMORY=1         # derive soft trait: notes from interaction patterns
# JARVIS_ENV_COACH=1                   # proactive suggestions from front app / battery
# JARVIS_AMBIENT_QUESTIONS=1           # rephrase nudges as gentle questions
# JARVIS_SOUND_MONITOR=auto            # auto-start doorbell/alarm listener (0 to disable)
# JARVIS_SOUND_ALERT_BURSTS=0          # speak on unidentified loud sounds
#
# --- Tier 3: continuity & proactive intelligence -----------------------------
# JARVIS_OPEN_LOOPS=1                  # track "I still need to…" commitments
# JARVIS_MOOD_PERSONA=0                # auto-switch persona from mood trajectory
# JARVIS_GLANCE_MODE=0                 # periodic screen glance during dev apps (1 or force)
# JARVIS_GLANCE_INTERVAL=300           # seconds between glances in glance mode
# JARVIS_VISION_SESSION_MIN=10         # minutes to keep discussing one image
# JARVIS_AUTO_LATE_SLACK=0             # auto-post running-late drafts to Slack
#
# --- Tier 4: always-on & cross-device ----------------------------------------
# JARVIS_ALWAYS_ON_WAKE=auto           # background wake listener (auto w/ passive mode)
# JARVIS_PASSIVE_MODE=1                # ignore speech until wake word / hotkey
# JARVIS_WAKE_WORD=jarvis,hey jarvis,friday,hey friday
# JARVIS_WAKE_MAX_SECONDS=3            # max utterance captured for wake detection
# JARVIS_HOTKEY=<cmd>+<shift>+j         # global hotkey wake (pip install pynput)
# JARVIS_FACE_ID=0                     # webcam face + voice fusion for multi-user
# JARVIS_FACE_THRESHOLD=0.88
# JARVIS_LOCAL_LLM=0                   # 0 | prefer | always | private
# JARVIS_OLLAMA_URL=http://localhost:11434
# JARVIS_OLLAMA_MODEL=llama3.2
# JARVIS_COMPANION=0                   # HTTP API for phone/Shortcuts
# JARVIS_COMPANION_HOST=127.0.0.1
# JARVIS_COMPANION_PORT=8765
# JARVIS_COMPANION_TOKEN=               # set if exposing beyond localhost
# JARVIS_SYNC_DIR=                      # iCloud/Dropbox folder for cross-device memory
# JARVIS_LIVE_CAMERA=0                 # auto | 1 — seated-too-long nudges
# JARVIS_LIVE_SCREEN=0                 # auto | 1 — stuck error detection
#
# --- Tier 5: hardware polish -----------------------------------------------
# JARVIS_PORCUPINE=auto                # on-device wake (pip install pvporcupine)
# PICOVOICE_ACCESS_KEY=                # console.picovoice.ai
# JARVIS_PORCUPINE_KEYWORDS=jarvis,computer
# JARVIS_PORCUPINE_SENSITIVITY=0.55
# JARVIS_MIC_DEVICE=                   # index or name substring for input mic
# JARVIS_MIC_GAIN=1.0
# JARVIS_MIC_NOISE_GATE=0              # int16 RMS floor (try 400-900 in noisy rooms)
# JARVIS_MIC_HIGHPASS=1                # cut HVAC rumble on directional mics
# JARVIS_MIC_AUTO_GAIN=0
# JARVIS_HOMEKIT_SHORTCUTS=1           # scenes/lights via macOS Shortcuts → Home
# JARVIS_HOMEKIT_ON_SHORTCUT=Jarvis Light On
# JARVIS_HOMEKIT_OFF_SHORTCUT=Jarvis Light Off
# JARVIS_HOMEKIT_DIM_SHORTCUT=Jarvis Dim Light
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
#
# --- Tier 6: routines & post-meeting -----------------------------------------
# JARVIS_ROUTINES=1                    # scheduled + focus-app automations
# JARVIS_ROUTINES_TICK=30              # poll interval (seconds)
# JARVIS_POST_MEETING=1                # prompt to capture notes after calls end
# JARVIS_POST_MEETING_GRACE_MIN=2      # wait after end before prompting
# JARVIS_POST_MEETING_WINDOW_MIN=20    # how long after end to still prompt


# -----------------------------------------------------------------------------
# 2. Voice output (TTS)
#    Order: ElevenLabs cloned voice → Microsoft neural (edge-tts) → pyttsx3 local
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=                # https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_VOICE_ID=               # voice id from ElevenLabs voice library
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# JARVIS_ELEVENLABS_ONLY=1             # don't fall back to other TTS

# Edge-TTS (Microsoft neural, free, online). `pip install edge-tts`.
# JARVIS_EDGE_TTS_VOICE=en-US-AriaNeural

# Offline only (skip ElevenLabs + Edge):
# JARVIS_USE_LOCAL_TTS=1
# JARVIS_PYTTSX3_VOICE_SUBSTRING=David


# -----------------------------------------------------------------------------
# 3. Voice input behavior
# -----------------------------------------------------------------------------
# JARVIS_LISTEN_TIMEOUT=                # blank = wait forever; or seconds
# JARVIS_PHRASE_SECONDS=15

# Wake-word / passive mode (assistant ignores you until you say a wake word)
# JARVIS_PASSIVE_MODE=1
# JARVIS_WAKE_WORD=jarvis,hey jarvis,friday,hey friday
# JARVIS_HOTKEY=<cmd>+<shift>+j         # needs `pip install pynput`

# Skip the filler phrase before slow operations:
# JARVIS_DISABLE_FILLER=1


# -----------------------------------------------------------------------------
# 4. Memory storage
#    Defaults to SQLite. Set DATABASE_URL or POSTGRES_* to use Postgres.
# -----------------------------------------------------------------------------
# JARVIS_MEMORY_BACKEND=auto            # auto | postgres | sqlite
# JARVIS_MEMORY_LINES=24                # rows injected into brain context
# JARVIS_MEMORY_SUMMARIZE_AFTER=60      # turns before LLM summary kicks in
# JARVIS_MEMORY_SUMMARIZE_BATCH=40      # oldest rows per summarization pass
# JARVIS_MEMORY_CONSOLIDATE_HOURS=24    # min interval between consolidations

# Postgres (also used for pgvector KB if JARVIS_VECTOR_BACKEND=postgres)
# DATABASE_URL=postgresql://user:pass@localhost:5432/jarvis
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=jarvis
# POSTGRES_USER=jarvis
# POSTGRES_PASSWORD=


# -----------------------------------------------------------------------------
# 5. Local knowledge base (RAG)
# -----------------------------------------------------------------------------
# JARVIS_KNOWLEDGE_DIR=                 # default: ./knowledge_docs
# JARVIS_CHUNK_MAX_CHARS=900
# JARVIS_VECTOR_BACKEND=chroma          # chroma (default) or postgres
# JARVIS_EMBEDDING_DIMENSION=            # override only if you change models


# -----------------------------------------------------------------------------
# 6. Live web search
#    Tavily if available, else free DuckDuckGo HTML scrape (no key needed).
# -----------------------------------------------------------------------------
TAVILY_API_KEY=


# -----------------------------------------------------------------------------
# 7. Daily briefing extras
# -----------------------------------------------------------------------------
JARVIS_DEFAULT_CITY=
OPENWEATHER_API_KEY=
NEWSAPI_KEY=                            # else briefing falls back to web search


# -----------------------------------------------------------------------------
# 8. Email + Slack handoff
# -----------------------------------------------------------------------------
JARVIS_SMTP_HOST=
JARVIS_SMTP_PORT=587                    # 465 for SSL, 587 for STARTTLS
JARVIS_SMTP_USER=
JARVIS_SMTP_PASS=
JARVIS_EMAIL_FROM=
JARVIS_EMAIL_TO_DEFAULT=
JARVIS_SLACK_WEBHOOK=


# -----------------------------------------------------------------------------
# 9. Calendar (macOS Calendar.app)
# -----------------------------------------------------------------------------
# JARVIS_CALENDAR_NAME=Home             # which calendar to write into


# -----------------------------------------------------------------------------
# 10. Cross-device sync (iCloud Drive / Dropbox / OneDrive folder)
# -----------------------------------------------------------------------------
# JARVIS_SYNC_DIR=$HOME/Library/Mobile Documents/com~apple~CloudDocs/Jarvis


# -----------------------------------------------------------------------------
# 11. System / safety toggles
# -----------------------------------------------------------------------------
# JARVIS_FILE_TOOLS=1                   # enables sandboxed open/list/read/delete
# JARVIS_TOOL_PATH_ROOTS=               # pipe-separated allowlisted roots
# JARVIS_ALLOW_PATH_EXECUTABLES=1       # allow brain to launch PATH binaries
# JARVIS_WINDOWS_ADMIN_TOOLS=1          # Windows only — opens elevated shell via UAC

JARVIS_PASSIVE_MODE=1
JARVIS_ALWAYS_ON_WAKE=auto
JARVIS_HOTKEY=<cmd>+<shift>+j
JARVIS_FACE_ID=1
JARVIS_LOCAL_LLM=prefer
JARVIS_OLLAMA_MODEL=llama3.2
JARVIS_COMPANION=1a
JARVIS_SYNC_DIR=~/Library/Mobile Documents/com~apple~CloudDocs/Jarvis

JARVIS_PORCUPINE=auto
PICOVOICE_ACCESS_KEY=
JARVIS_MIC_HIGHPASS=1
JARVIS_HOMEKIT_SHORTCUTS=1
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

JARVIS_ROUTINES=1
JARVIS_POST_MEETING=1
JARVIS_POST_MEETING_GRACE_MIN=2
JARVIS_POST_MEETING_WINDOW_MIN=20